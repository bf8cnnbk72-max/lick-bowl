<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LICK</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0e0b14;
    --surface: #181320;
    --border: #2e2340;
    --accent: #c084fc;
    --accent2: #f472b6;
    --text: #e8e0f0;
    --muted: #7c6a99;
    --success: #86efac;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 16px 48px;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(2rem, 6vw, 3.2rem);
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-align: center;
    margin-bottom: 4px;
  }

  .tagline {
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 32px;
    text-align: center;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    width: 100%;
    max-width: 480px;
    margin-bottom: 16px;
  }

  .card h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--accent);
  }

  label {
    display: block;
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 6px;
    margin-top: 12px;
  }

  input[type="text"] {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 11px 14px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
  }

  input[type="text"]:focus {
    border-color: var(--accent);
  }

  input[type="text"]::placeholder { color: var(--muted); }

  .btn {
    display: block;
    width: 100%;
    margin-top: 20px;
    padding: 13px;
    border: none;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
  }

  .btn:active { transform: scale(0.98); }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #0e0b14;
  }

  .btn-secondary {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    margin-top: 10px;
  }

  .btn-reveal {
    background: linear-gradient(135deg, #f472b6, #fb923c);
    color: #0e0b14;
    font-size: 1.1rem;
    padding: 16px;
    border-radius: 12px;
    margin-top: 0;
  }

  .btn:hover { opacity: 0.88; }

  .count-badge {
    display: inline-block;
    background: var(--border);
    color: var(--accent);
    border-radius: 20px;
    padding: 2px 10px;
    font-size: 0.8rem;
    margin-left: 8px;
  }

  /* Screens */
  .screen { display: none; width: 100%; max-width: 480px; flex-direction: column; align-items: center; }
  .screen.active { display: flex; }

  /* Reveal card */
  .reveal-card {
    background: linear-gradient(145deg, #1e1530, #2a1545);
    border: 1px solid #4a2d6e;
    border-radius: 20px;
    padding: 32px 24px;
    text-align: center;
    width: 100%;
    max-width: 480px;
    margin-bottom: 20px;
  }

  .reveal-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .kink-list {
    list-style: none;
    margin: 20px 0 0;
  }

  .kink-list li {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.4rem;
    color: var(--text);
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }

  .kink-list li:last-child { border-bottom: none; }

  .kink-num {
    font-family: 'DM Sans', sans-serif;
    font-style: normal;
    font-size: 0.7rem;
    color: var(--accent);
    margin-right: 8px;
    letter-spacing: 0.1em;
  }

  .round-info {
    color: var(--muted);
    font-size: 0.85rem;
    margin-bottom: 16px;
  }

  .remaining-count {
    font-size: 0.8rem;
    color: var(--muted);
    text-align: center;
    margin-top: 12px;
  }

  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--success);
    color: #0e0b14;
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: transform 0.3s ease;
    pointer-events: none;
    white-space: nowrap;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  .mode-toggle {
    display: flex;
    gap: 10px;
    width: 100%;
    max-width: 480px;
    margin-bottom: 16px;
  }

  .mode-btn {
    flex: 1;
    padding: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--muted);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .mode-btn.active {
    background: var(--border);
    border-color: var(--accent);
    color: var(--accent);
  }

  .admin-screen-wrapper {
    width: 100%;
    max-width: 480px;
  }

  .entry-preview {
    background: var(--bg);
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 8px;
    font-size: 0.85rem;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .entry-preview span { color: var(--text); }

  .delete-btn {
    background: none;
    border: none;
    color: #4a2d6e;
    cursor: pointer;
    font-size: 1rem;
    padding: 2px 6px;
  }

  .delete-btn:hover { color: var(--accent2); }

  .confetti {
    position: fixed;
    pointer-events: none;
    width: 100vw;
    height: 100vh;
    top: 0; left: 0;
    overflow: hidden;
    z-index: 999;
  }

  .particle {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    animation: fall linear forwards;
  }

  @keyframes fall {
    0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }
</style>
</head>
<body>

<h1>LICK</h1>

<!-- Mode toggle -->
<div class="mode-toggle" id="modeToggle">
  <button class="mode-btn active" onclick="showMode('submit')">Submit</button>
  <button class="mode-btn" onclick="showMode('admin')">Draw</button>
</div>

<!-- SUBMIT SCREEN -->
<div class="screen active" id="submitScreen">
  <div class="card">
    <h2>Drop your kinks</h2>
    <p style="font-size:0.85rem; color:var(--muted); margin-bottom:4px;">Anonymous. No names. Just vibes.</p>

    <label>Kink #1</label>
    <input type="text" id="k1" placeholder="e.g. praise kink" maxlength="60">

    <label>Kink #2</label>
    <input type="text" id="k2" placeholder="e.g. bondage" maxlength="60">

    <label>Kink #3</label>
    <input type="text" id="k3" placeholder="e.g. sensory play" maxlength="60">

    <button class="btn btn-primary" onclick="submitEntry()">Toss into the bowl 🥣</button>
  </div>
</div>

<!-- ADMIN / DRAW SCREEN -->
<div class="screen" id="adminScreen">
  <div class="admin-screen-wrapper">

    <div class="card" id="drawSection" style="text-align:center;">
      <h2>LICK <span class="count-badge" id="countBadge">0 entries</span></h2>
      <p style="font-size:0.85rem; color:var(--muted); margin-bottom:20px;">Draw one mystery set at a time. The group guesses who!</p>
      <button class="btn btn-reveal" onclick="drawEntry()" id="drawBtn">Draw from the bowl</button>
      <p class="remaining-count" id="remainingCount"></p>
    </div>

    <!-- Reveal -->
    <div id="revealSection" style="display:none; width:100%;">
      <div class="reveal-card">
        <div class="reveal-label">Mystery person's kinks</div>
        <ul class="kink-list" id="revealList"></ul>
      </div>
      <button class="btn btn-primary" onclick="nextDraw()">Draw next</button>
      <button class="btn btn-secondary" onclick="backToBowl()">↩ Back to bowl</button>
    </div>

    <!-- Entries list -->
    <div class="card" style="margin-top:8px;">
      <h2>Entries <span class="count-badge" id="listCount">0</span></h2>
      <div id="entryList"><p style="color:var(--muted); font-size:0.85rem;">No entries yet.</p></div>
      <button class="btn btn-secondary" onclick="clearAll()" style="margin-top:12px;">Clear all entries</button>
    </div>

  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>
<!-- Confetti container -->
<div class="confetti" id="confetti"></div>

<script>
  // Storage key
  const KEY = 'lick_bowl_entries';
  const DRAWN_KEY = 'lick_bowl_drawn';

  function getEntries() {
    return JSON.parse(localStorage.getItem(KEY) || '[]');
  }

  function getDrawn() {
    return JSON.parse(localStorage.getItem(DRAWN_KEY) || '[]');
  }

  function saveEntries(arr) {
    localStorage.setItem(KEY, JSON.stringify(arr));
  }

  function saveDrawn(arr) {
    localStorage.setItem(DRAWN_KEY, JSON.stringify(arr));
  }

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2200);
  }

  function submitEntry() {
    const k1 = document.getElementById('k1').value.trim();
    const k2 = document.getElementById('k2').value.trim();
    const k3 = document.getElementById('k3').value.trim();

    if (!k1 || !k2 || !k3) {
      showToast('Fill in all 3 kinks first!');
      return;
    }

    const entries = getEntries();
    entries.push({ id: Date.now(), kinks: [k1, k2, k3] });
    saveEntries(entries);

    document.getElementById('k1').value = '';
    document.getElementById('k2').value = '';
    document.getElementById('k3').value = '';

    showToast('Dropped into the bowl! 🥣');
    updateAdminUI();
    confettiBurst();
  }

  function drawEntry() {
    const entries = getEntries();
    const drawn = getDrawn();
    const remaining = entries.filter(e => !drawn.includes(e.id));

    if (remaining.length === 0) {
      showToast('Bowl is empty! All entries drawn.');
      return;
    }

    const pick = remaining[Math.floor(Math.random() * remaining.length)];
    drawn.push(pick.id);
    saveDrawn(drawn);

    // Show reveal
    const list = document.getElementById('revealList');
    list.innerHTML = pick.kinks.map((k, i) =>
      `<li><span class="kink-num">#${i+1}</span>${k}</li>`
    ).join('');

    document.getElementById('drawSection').style.display = 'none';
    document.getElementById('revealSection').style.display = 'block';

    updateAdminUI();
    confettiBurst();
  }

  function nextDraw() {
    document.getElementById('revealSection').style.display = 'none';
    document.getElementById('drawSection').style.display = 'block';
    drawEntry();
  }

  function backToBowl() {
    document.getElementById('revealSection').style.display = 'none';
    document.getElementById('drawSection').style.display = 'block';
    updateAdminUI();
  }

  function updateAdminUI() {
    const entries = getEntries();
    const drawn = getDrawn();
    const remaining = entries.filter(e => !drawn.includes(e.id));

    document.getElementById('countBadge').textContent =
      entries.length === 1 ? '1 entry' : `${entries.length} entries`;
    document.getElementById('listCount').textContent = entries.length;
    document.getElementById('remainingCount').textContent =
      remaining.length > 0
        ? `${remaining.length} left in the bowl`
        : entries.length > 0 ? 'All drawn!' : '';

    const listEl = document.getElementById('entryList');
    if (entries.length === 0) {
      listEl.innerHTML = '<p style="color:var(--muted); font-size:0.85rem;">No entries yet.</p>';
    } else {
      listEl.innerHTML = entries.map((e, i) =>
        `<div class="entry-preview">
          <span>Entry ${i+1}: ${e.kinks.map(k => `<em>${k}</em>`).join(', ')}</span>
          <button class="delete-btn" onclick="deleteEntry(${e.id})">✕</button>
        </div>`
      ).join('');
    }
  }

  function deleteEntry(id) {
    let entries = getEntries();
    entries = entries.filter(e => e.id !== id);
    saveEntries(entries);
    let drawn = getDrawn();
    drawn = drawn.filter(d => d !== id);
    saveDrawn(drawn);
    updateAdminUI();
    showToast('Entry removed.');
  }

  function clearAll() {
    if (!confirm('Clear all entries and start fresh?')) return;
    localStorage.removeItem(KEY);
    localStorage.removeItem(DRAWN_KEY);
    document.getElementById('revealSection').style.display = 'none';
    document.getElementById('drawSection').style.display = 'block';
    updateAdminUI();
    showToast('Bowl cleared!');
  }

  function showMode(mode) {
    document.querySelectorAll('.mode-btn').forEach((b, i) => {
      b.classList.toggle('active', (i === 0 && mode === 'submit') || (i === 1 && mode === 'admin'));
    });
    document.getElementById('submitScreen').classList.toggle('active', mode === 'submit');
    document.getElementById('adminScreen').classList.toggle('active', mode === 'admin');
    if (mode === 'admin') updateAdminUI();
  }

  function confettiBurst() {
    const container = document.getElementById('confetti');
    const colors = ['#c084fc', '#f472b6', '#fb923c', '#86efac', '#67e8f9'];
    for (let i = 0; i < 30; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.left = Math.random() * 100 + 'vw';
      p.style.top = '-10px';
      p.style.background = colors[Math.floor(Math.random() * colors.length)];
      p.style.animationDuration = (1.2 + Math.random() * 1.5) + 's';
      p.style.animationDelay = Math.random() * 0.4 + 's';
      p.style.width = p.style.height = (6 + Math.random() * 8) + 'px';
      container.appendChild(p);
      setTimeout(() => p.remove(), 3000);
    }
  }

  // Init
  updateAdminUI();
</script>
</body>
</html>
